# Copy to .env on a cloud server if you want a single place for local paths.
# Do not commit real tokens or private paths.

PROJECT_ROOT=/workspace/paper_reproduce
DATA_ROOT=/workspace/paper_reproduce/data
MODEL_ROOT=/workspace/paper_reproduce/models
OUTPUT_ROOT=/workspace/paper_reproduce/outputs

# Optional Hugging Face token for gated/private downloads.
HF_TOKEN=

# Default model IDs and local paths used by docs/scripts.
LLAVA_MODEL_ID=llava-hf/llava-1.5-7b-hf
LLAVA_LOCAL_DIR=/workspace/paper_reproduce/models/llava-1.5-7b-hf
GROUNDINGDINO_REPO_DIR=/workspace/paper_reproduce/models/GroundingDINO
GROUNDINGDINO_CONFIG=/workspace/paper_reproduce/models/GroundingDINO/groundingdino/config/GroundingDINO_SwinT_OGC.py
GROUNDINGDINO_CHECKPOINT=/workspace/paper_reproduce/models/groundingdino_swint_ogc.pth

CUDA_VISIBLE_DEVICES=0
